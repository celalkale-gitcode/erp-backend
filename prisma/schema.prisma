
model Urunler {
  id Int @id @default(autoincrement())
  urunAdi String
  modelKodu String
  barkodu String
  stokAdedi Int
  magazaId Int
  varyantId Int
  kayitTarihi DateTime

  barkodlar UrunBarkodlari[]
}

model UrunBarkodlari {
  id Int @id @default(autoincrement())
  urunId Int
  sistemBarkod String @unique

  urun Urunler @relation(fields: [urunId], references: [id])
}

model StokHareketleri {
  id Int @id @default(autoincrement())
  urunId Int
  tip String
  miktar Int
  oncekiStok Int
  sonrakiStok Int

  latitude Float?
  longitude Float?
  lokasyonKodu String?

  tarih DateTime @default(now())
}

model Iadeler {
  id Int @id @default(autoincrement())
  durum String
  islenmeTarihi DateTime?
}

model IadeKalemleri {
  id Int @id @default(autoincrement())
  iadeId Int
  urunId Int
  adet Int
  stokEtkisi Boolean
  islenmis Boolean @default(false)
}
