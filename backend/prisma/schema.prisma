model Urunler {
  id           Int @id @default(autoincrement())
  urun_adi     String?
  stok_adedi   Int?
  satis_fiyati Float?

  barkodlar UrunBarkodlari[]
}

model UrunBarkodlari {
  id            Int @id @default(autoincrement())
  urun_id       Int?
  sistem_barkod String? @unique

  urun Urunler? @relation(fields: [urun_id], references: [id])
}

model StokHareketleri {
  id           Int @id @default(autoincrement())
  urun_id      Int?
  miktar       Int?
  tip          String?

  urun Urunler? @relation(fields: [urun_id], references: [id])
}

model IadeKalemleri {
  id          Int @id @default(autoincrement())
  iade_id     Int?
  urun_id     Int?
  adet        Int?
  stok_etkisi Boolean?
}
