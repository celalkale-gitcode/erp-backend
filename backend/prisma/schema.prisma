model urunler {
  id          Int     @id @default(autoincrement())
  urun_adi    String?
  barkod      String?
  stok_adedi  Int     @default(0)

  stoklar     stok_hareketleri[]
  iadeler     iadeler[]
  lokasyonlar lokasyon_urunleri[]
}

model stok_hareketleri {
  id        Int      @id @default(autoincrement())
  urun_id   Int
  tip       String
  miktar    Int
  latitude  Float?
  longitude Float?
  tarih     DateTime @default(now())

  urun urunler @relation(fields: [urun_id], references: [id])
}

model iadeler {
  id          Int      @id @default(autoincrement())
  urun_id     Int
  adet        Int
  iade_tarihi DateTime @default(now())

  urun urunler @relation(fields: [urun_id], references: [id])
}

model lokasyonlar {
  id             BigInt @id @default(autoincrement())
  lokasyon_kodu  String
  aciklama       String?

  urunler lokasyon_urunleri[]
}

model lokasyon_urunleri {
  id           Int    @id @default(autoincrement())
  lokasyon_id  BigInt
  urun_id      Int
  beden        String

  lokasyon lokasyonlar @relation(fields: [lokasyon_id], references: [id])
  urun     urunler     @relation(fields: [urun_id], references: [id])

  @@unique([lokasyon_id, urun_id, beden]) // 🔥 önemli
}
